{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "bun-types"
    ],
    "paths": {
      "agent-tui": [
        "./packages/agent-tui/src/index.ts"
      ],
      "agent-tui/*": [
        "./packages/agent-tui/src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "packages/**/*.ts"
  ]
}
